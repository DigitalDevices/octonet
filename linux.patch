diff -Naur linux-3.17.8/arch/arm/mach-at91/octonet_hw_init.c linux.octonet.ok/arch/arm/mach-at91/octonet_hw_init.c
--- linux-3.17.8/arch/arm/mach-at91/octonet_hw_init.c	1970-01-01 01:00:00.000000000 +0100
+++ linux.octonet.ok/arch/arm/mach-at91/octonet_hw_init.c	2026-04-29 21:20:49.942867704 +0200
@@ -0,0 +1,87 @@
+#include <linux/module.h>
+#include <linux/init.h>
+#include <linux/io.h>
+#include <linux/delay.h>
+
+/* Physikalische Basisadresse der Matrix beim AT91SAM9G45 */
+#define AT91_MATRIX_PHYS_BASE 0xffffea00
+#define AT91_MATRIX_SCFG4     0x40
+#define AT91_MATRIX_PRBS4     0x84
+
+/* Shutdown Controller */
+#define AT91_SHDW_PHYS_BASE   0xfffffd10
+#define AT91_SHDW_MR          0x04
+
+static int __init octonet_hw_init_safe(void)
+{
+    void __iomem *matrix;
+    void __iomem *shdw;
+
+    pr_info("Octonet: Late Hardware Fixup...\n");
+
+    /* Matrix-Mapping */
+    matrix = ioremap(AT91_MATRIX_PHYS_BASE, 0x200);
+    if (matrix) {
+        writel((8 << 18) | (2 << 16), matrix + AT91_MATRIX_SCFG4);
+        writel(0x00000003, matrix + AT91_MATRIX_PRBS4);
+        iounmap(matrix);
+        pr_info("Octonet: Matrix registers set.\n");
+    }
+
+    /* Shutdown-Mapping */
+    shdw = ioremap(AT91_SHDW_PHYS_BASE, 0x10);
+    if (shdw) {
+        writel(0x30003, shdw + AT91_SHDW_MR);
+        iounmap(shdw);
+        pr_info("Octonet: Shutdown controller set.\n");
+    }
+
+    return 0;
+}
+
+static int __init octonet_final_fixup(void)
+{
+    void __iomem *r;
+
+    pr_info("Octonet: Starting Combined Hardware Fixup\n");
+
+    /* 1. Matrix Fixup: CPU Priority on System Bus */
+    r = ioremap(0xffffea00, 0x200);
+    if (r) {
+        writel((8 << 18) | (2 << 16), r + 0x50); // SCFG4
+        writel(0x00000003, r + 0xa0);           // PRBS4
+        iounmap(r);
+        pr_info("Octonet: Bus Matrix priority set\n");
+    }
+
+    /* 2. Shutdown & Alarm Fixup */
+    r = ioremap(0xfffffd10, 0x100);
+    if (r) {
+        writel(0x30003, r + 0x04); // SHDW_MR
+        writel(0x02, r + 0xbc);    // Alarm Reset (Offset von fffffd10 aus gesehen)
+        iounmap(r);
+        pr_info("Octonet: Shutdown & Alarm fixed\n");
+    }
+
+    /* 3. Slow Clock Fixup (Die 1.4s Sequenz) */
+    r = ioremap(0xfffffd50, 0x4);
+    if (r) {
+        if (readl(r) == 1) {
+            pr_info("Octonet: Starting Slow Clock XTAL sync (1.4s)...\n");
+            writel(0x03, r); mdelay(1400);
+            writel(0x0b, r); mdelay(1);
+            writel(0x0a, r);
+            pr_info("Octonet: Slow Clock XTAL stable\n");
+        }
+        iounmap(r);
+    }
+
+    return 0;
+}
+arch_initcall(octonet_final_fixup);
+
+/* subsys_initcall läuft spät genug für ioremap, aber vor den Treibern */
+//subsys_initcall(octonet_hw_init_safe);
+
+MODULE_LICENSE("GPL");
+
