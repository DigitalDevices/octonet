+static void set_alarm(void)
+{
+	void __iomem *r = ioremap(0xfffff000, 0x1000);
+
+	if (!r)
+		return;
+	writel(0x02, r + 0xdcc); /* reset ALARM clock state */
+	iounmap(r);
+}
+
+static void set_slowclock(void)
+{
+	void __iomem *r = ioremap(0xfffff000, 0x1000);
+
+	if (!r)
+		return;
+	//writel(0x02, r + 0xdcc); /* reset ALARM clock state */
+        if (readl(r + SCKCR) == 1) {
+                writel(0x03, r + SCKCR);
+                mdelay(1400);
+                writel(0x0b, r + SCKCR);
+                mdelay(1);
+                writel(0x0a, r + SCKCR);
+        }
+	iounmap(r);
+}
